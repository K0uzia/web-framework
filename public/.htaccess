# dev.lacapsule.org/wf — document root = ce dossier (public/).

DirectoryIndex index.php

<IfModule mod_env.c>
    SetEnv APP_BASE_PATH /wf
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /wf/

    RewriteRule .* - [E=APP_BASE_PATH:/wf]

    # Favicon navigateur (évite 404 console sur /wf/favicon.ico)
    RewriteRule ^favicon\.ico$ favicon.svg [L]

    # Fichiers statiques existants uniquement (pas les dossiers : sinon 403).
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Front controller : /, /dev, /api/*, pages dynamiques
    RewriteRule ^ index.php [L,QSA]
</IfModule>

<IfModule !mod_rewrite.c>
    FallbackResource /wf/index.php
</IfModule>

<IfModule mod_rewrite.c>
    RewriteRule ^uploads/.+\.php$ - [F,L]
</IfModule>

Options -Indexes
