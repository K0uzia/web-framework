# Production lacapsule.org : document root = ce dossier, URL publique = /wf/
# Pages publiques, /dev, /api/* passent par index.php.

DirectoryIndex index.php

# PHP (Apache mod_php et la plupart des configs FPM via Apache)
<IfModule mod_env.c>
    SetEnv APP_BASE_PATH /wf
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /wf/

    # Expose APP_BASE_PATH aux setups PHP-FPM + proxy_fcgi
    RewriteRule .* - [E=APP_BASE_PATH:/wf]

    # Fichiers et dossiers existants servis tels quels (assets, uploads, etc.).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Front controller
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Pas d'exécution PHP dans les uploads
<IfModule mod_rewrite.c>
    RewriteRule ^uploads/.+\.php$ - [F,L]
</IfModule>

Options -Indexes
