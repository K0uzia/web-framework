# Hébergement mutualisé : document root = racine du dépôt (pas public/).
# Le chemin URL (/wf, /mon-app, etc.) est détecté automatiquement par PHP (SCRIPT_NAME).

DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloque l'accès HTTP direct au code source.
    RewriteRule ^(?:app|bin|bootstrap|config|data|migrations|resources|scripts|src|tests|vendor)(?:/|$) - [F,L]
    RewriteRule (^|/)\. - [F,L]

    # Assets statiques : fichiers réels dans public/ uniquement.
    # Règles explicites (fiables en FTP / sous-dossier /wf).
    RewriteRule ^assets/(.*)$ public/assets/$1 [L]
    RewriteRule ^uploads/(.*)$ public/uploads/$1 [L]
    RewriteRule ^favicon\.(ico|svg)$ public/favicon.$1 [L]

    # Autres fichiers présents dans public/ (deploy-check.php, etc.).
    RewriteCond public/$1 -f
    RewriteRule ^([^/]+)$ public/$1 [L]

    # Front controller (y compris / et /dev).
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ public/index.php [L,QSA]
</IfModule>

<IfModule !mod_rewrite.c>
    FallbackResource public/index.php
</IfModule>

Options -Indexes
