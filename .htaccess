# dev.lacapsule.org/wf — document root = racine du dépôt (pas public/).

DirectoryIndex index.php index.html

<IfModule mod_env.c>
    SetEnv APP_BASE_PATH /wf
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /wf/

    RewriteRule .* - [E=APP_BASE_PATH:/wf]

    # Bloque l'accès HTTP direct au code source (chemins relatifs à /wf/).
    RewriteRule ^(?:app|bin|bootstrap|config|data|migrations|resources|scripts|src|tests|vendor)(?:/|$) - [F,L]
    RewriteRule (^|/)\. - [F,L]

    # Assets statiques : fichiers réels dans public/ uniquement.
    RewriteCond %{DOCUMENT_ROOT}/public/$1 -f
    RewriteRule ^(.+)$ public/$1 [L]

    # Front controller (y compris /wf/ et /wf/dev — ne pas traiter les dossiers comme fin de chaîne).
    RewriteRule ^ public/index.php [L,QSA]
</IfModule>

<IfModule !mod_rewrite.c>
    FallbackResource /wf/public/index.php
</IfModule>

Options -Indexes
